}

model Coupon {
  id           String        @id @default(cuid())
  code         String        @unique
  type         CouponType
  value        Int // Amount or percentage
  applicableOn Json // ["DEMO", "30MIN", "60MIN", "GROUP", "CRASH", "FULL"] - Refactored for MySQL - Author: Sanket
  teacherId    String? // Null means global
  expiryDate   DateTime
  usageLimit   Int           @default(100)
  usedCount    Int           @default(0)
  perUserLimit Int           @default(1)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  usage        CouponUsage[]

  @@map("coupons")
}

enum CouponType {
  FIXED
  PERCENTAGE
}

model FreeClassUsage {
