  groupUsed      Boolean  @default(false)
  demoSessionId  String? // Reference to the session used
  groupSessionId String? // Reference to the group class used
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("free_class_usage")
}

// Free Trial System - Per-Teacher Email-Based Tracking
// Author: Sanket
// Tracks which students have used their free trial with each teacher
model FreeTrialUsage {
  id String @id @default(cuid())

  // Student info (email-based to prevent multi-account abuse)
  studentId    String
  studentEmail String // Primary tracking field
  student      User   @relation("StudentFreeTrials", fields: [studentId], references: [id], onDelete: Cascade)

  // Teacher info
  teacherId String
  teacher   TeacherProfile @relation("TeacherFreeTrials", fields: [teacherId], references: [id], onDelete: Cascade)

  // Session info
  sessionType String // "live_session" or "group_class"
  sessionId   String // ID of the LiveSession or GroupClass

  // Timestamps
  usedAt    DateTime @default(now())
  createdAt DateTime @default(now())

  // Ensure one free trial per email per teacher
  @@unique([studentEmail, teacherId])
  @@index([studentId, teacherId])
  @@index([teacherId])
  @@map("free_trial_usage")
}

model StudentSavedTutor {
